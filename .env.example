# Initial admin bootstrap
# Created during the first migration only when both values are non-empty.
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-this-admin-password

# JWT
# Replace this before production deployment.
JWT_SECRET_KEY=replace-with-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# PostgreSQL
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=pyboard_admin
PG_PASSWORD=change-this-postgres-password
PG_DATABASE=pyboard_db

# Database pool
POOL_SIZE=50
MAX_OVERFLOW=30

# PostgreSQL queue worker
QUEUE_DEFAULT_NAME=default
QUEUE_MAX_JOBS=20
QUEUE_POLL_DELAY=0.5
QUEUE_MAX_TRIES=3
QUEUE_RETRY_JOBS=true
QUEUE_HEALTH_CHECK_INTERVAL=300
