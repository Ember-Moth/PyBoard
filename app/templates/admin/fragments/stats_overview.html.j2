<div class="row g-3">
  <div class="col-sm-6 col-lg-3">
    <div class="card"><div class="card-body"><div class="text-secondary">订单数</div><div class="h2 mb-0">{{ overview.order_count or 0 }}</div></div></div>
  </div>
  <div class="col-sm-6 col-lg-3">
    <div class="card"><div class="card-body"><div class="text-secondary">订单金额</div><div class="h2 mb-0">{{ "%.2f"|format((overview.order_total or 0) / 100) }}</div></div></div>
  </div>
  <div class="col-sm-6 col-lg-3">
    <div class="card"><div class="card-body"><div class="text-secondary">已支付数</div><div class="h2 mb-0">{{ overview.paid_count or 0 }}</div></div></div>
  </div>
  <div class="col-sm-6 col-lg-3">
    <div class="card"><div class="card-body"><div class="text-secondary">已支付金额</div><div class="h2 mb-0">{{ "%.2f"|format((overview.paid_total or 0) / 100) }}</div></div></div>
  </div>
  <div class="col-lg-4">
    <div class="card">
      <div class="card-header"><div class="card-title">节点流量排行</div></div>
      <div class="table-responsive">
        <table class="table card-table table-vcenter">
          <thead><tr><th>节点</th><th>类型</th><th>总流量</th></tr></thead>
          <tbody>
            {% for item in server_rank %}
            <tr><td>{{ item.server_id }}</td><td>{{ item.server_type }}</td><td>{{ item.total }}</td></tr>
            {% else %}
            <tr><td colspan="3" class="text-center text-secondary py-4">暂无数据</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-lg-4">
    <div class="card">
      <div class="card-header"><div class="card-title">用户流量排行</div></div>
      <div class="table-responsive">
        <table class="table card-table table-vcenter">
          <thead><tr><th>用户</th><th>倍率</th><th>总流量</th></tr></thead>
          <tbody>
            {% for item in user_rank %}
            <tr><td>{{ item.user_id }}</td><td>{{ item.server_rate }}</td><td>{{ item.total }}</td></tr>
            {% else %}
            <tr><td colspan="3" class="text-center text-secondary py-4">暂无数据</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-lg-4">
    <div class="card">
      <div class="card-header"><div class="card-title">统计快照</div></div>
      <div class="table-responsive">
        <table class="table card-table table-vcenter">
          <thead><tr><th>时间</th><th>订单</th><th>支付</th></tr></thead>
          <tbody>
            {% for item in orders %}
            <tr><td>{{ item.record_at }}</td><td>{{ item.order_count }}</td><td>{{ item.paid_count }}</td></tr>
            {% else %}
            <tr><td colspan="3" class="text-center text-secondary py-4">暂无快照</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
