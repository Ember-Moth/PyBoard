{% set is_create = coupon is none %}
<div class="modal modal-blur d-block" tabindex="-1" role="dialog">
  <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
    <div class="modal-content">
      <form hx-post="{% if is_create %}/admin/actions/coupons{% else %}/admin/actions/coupons/{{ coupon.id }}{% endif %}" hx-target="#modal-root" hx-swap="innerHTML">
        <input type="hidden" name="csrf_token" value="{{ request.cookies.get('admin_csrf') }}">
        <div class="modal-header">
          <h5 class="modal-title">{% if is_create %}创建优惠券{% else %}编辑优惠券 #{{ coupon.id }}{% endif %}</h5>
          <button type="button" class="btn-close" onclick="document.getElementById('modal-root').innerHTML=''"></button>
        </div>
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">名称</label>
              <input name="name" class="form-control" value="{{ coupon.name if coupon else '' }}" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">券码</label>
              <input name="code" class="form-control" value="{{ coupon.code if coupon else '' }}" placeholder="留空自动生成">
            </div>
            <div class="col-md-4">
              <label class="form-label">类型</label>
              <select name="type" class="form-select" required>
                <option value="1" {% if coupon and coupon.type == 1 %}selected{% endif %}>固定金额</option>
                <option value="2" {% if coupon and coupon.type == 2 %}selected{% endif %}>百分比</option>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label">面值</label>
              <input name="value" type="number" min="1" class="form-control" value="{{ coupon.value if coupon else '' }}" required>
            </div>
            <div class="col-md-4">
              <label class="form-label">总次数</label>
              <input name="limit_use" type="number" min="0" class="form-control" value="{{ coupon.limit_use if coupon and coupon.limit_use is not none else '' }}">
            </div>
            <div class="col-md-4">
              <label class="form-label">单用户次数</label>
              <input name="limit_use_with_user" type="number" min="0" class="form-control" value="{{ coupon.limit_use_with_user if coupon and coupon.limit_use_with_user is not none else '' }}">
            </div>
            <div class="col-md-4">
              <label class="form-label">开始时间</label>
              <input name="started_at" type="datetime-local" class="form-control" value="{{ coupon.started_at | datetime_input if coupon else '' }}" required>
            </div>
            <div class="col-md-4">
              <label class="form-label">结束时间</label>
              <input name="ended_at" type="datetime-local" class="form-control" value="{{ coupon.ended_at | datetime_input if coupon else '' }}" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">适用套餐</label>
              <input name="limit_plan_ids" class="form-control" value="{{ coupon.limit_plan_ids if coupon and coupon.limit_plan_ids else '' }}">
            </div>
            <div class="col-md-6">
              <label class="form-label">限制周期</label>
              <input name="limit_period" class="form-control" value="{{ coupon.limit_period if coupon and coupon.limit_period else '' }}">
            </div>
            <div class="col-12">
              <label class="form-check">
                <input class="form-check-input" type="checkbox" name="show" value="1" {% if is_create or coupon.show %}checked{% endif %}>
                <span class="form-check-label">启用</span>
              </label>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn" onclick="document.getElementById('modal-root').innerHTML=''">取消</button>
          <button type="submit" class="btn btn-primary">{% if is_create %}创建{% else %}保存{% endif %}</button>
        </div>
      </form>
    </div>
  </div>
</div>
<div class="modal-backdrop fade show"></div>
