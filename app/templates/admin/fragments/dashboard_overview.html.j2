{% macro metric_card(label, value) -%}
<div class="col-12 col-sm-6 col-lg-4 col-xl">
  <div class="card h-100">
    <div class="card-body">
      <div class="subheader">{{ label }}</div>
      <div class="h1 mb-0 text-truncate">{{ value }}</div>
    </div>
  </div>
</div>
{%- endmacro %}

<div class="row row-cards">
  {{ metric_card("订单数", overview.order_count or 0) }}
  {{ metric_card("订单金额", "%.2f"|format((overview.order_total or 0) / 100)) }}
  {{ metric_card("已支付订单", overview.paid_count or 0) }}
  {{ metric_card("成交金额", "%.2f"|format((overview.paid_total or 0) / 100)) }}
  {{ metric_card("失败任务", queue.failed_jobs) }}
</div>

<div class="row row-cards mt-3">
  <div class="col-12 col-xl-8">
    <div class="card h-100">
      <div class="card-header">
        <h3 class="card-title">统计快照</h3>
      </div>
      <div class="table-responsive">
        <table class="table table-vcenter card-table">
          <thead>
            <tr>
              <th>时间</th>
              <th class="text-end">订单</th>
              <th class="text-end">支付</th>
              <th class="text-end">支付金额</th>
            </tr>
          </thead>
          <tbody>
            {% for item in orders %}
            <tr>
              <td class="text-nowrap">{{ item.record_at | datetime }}</td>
              <td class="text-end">{{ item.order_count }}</td>
              <td class="text-end">{{ item.paid_count }}</td>
              <td class="text-end">{{ "%.2f"|format((item.paid_total or 0) / 100) }}</td>
            </tr>
            {% else %}
            <tr><td colspan="4" class="text-center text-secondary py-4">暂无快照</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="col-12 col-xl-4">
    <div class="card h-100">
      <div class="card-header">
        <h3 class="card-title">系统状态</h3>
      </div>
      <div class="table-responsive">
        <table class="table table-vcenter card-table">
          <tbody>
            <tr>
              <td class="text-secondary text-nowrap">Python</td>
              <td class="text-end text-nowrap">{{ system.python }}</td>
            </tr>
            <tr>
              <td class="text-secondary text-nowrap">平台</td>
              <td class="text-end">{{ system.platform }}</td>
            </tr>
            <tr>
              <td class="text-secondary text-nowrap">磁盘使用</td>
              <td class="text-end text-nowrap">{{ system.disk.used }} / {{ system.disk.total }}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<div class="row row-cards mt-3">
  <div class="col-12 col-xl-6">
    <div class="card h-100">
      <div class="card-header">
        <h3 class="card-title">节点流量排行</h3>
      </div>
      <div class="table-responsive">
        <table class="table table-vcenter card-table">
          <thead>
            <tr>
              <th>节点</th>
              <th>类型</th>
              <th class="text-end">总流量</th>
            </tr>
          </thead>
          <tbody>
            {% for item in server_rank %}
            <tr>
              <td class="text-nowrap">{{ item.server_id }}</td>
              <td>{{ item.server_type }}</td>
              <td class="text-end text-nowrap">{{ item.total }}</td>
            </tr>
            {% else %}
            <tr><td colspan="3" class="text-center text-secondary py-4">暂无数据</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="col-12 col-xl-6">
    <div class="card h-100">
      <div class="card-header">
        <h3 class="card-title">用户流量排行</h3>
      </div>
      <div class="table-responsive">
        <table class="table table-vcenter card-table">
          <thead>
            <tr>
              <th>用户</th>
              <th class="text-end">倍率</th>
              <th class="text-end">总流量</th>
            </tr>
          </thead>
          <tbody>
            {% for item in user_rank %}
            <tr>
              <td class="text-nowrap">{{ item.user_id }}</td>
              <td class="text-end">{{ item.server_rate }}</td>
              <td class="text-end text-nowrap">{{ item.total }}</td>
            </tr>
            {% else %}
            <tr><td colspan="3" class="text-center text-secondary py-4">暂无数据</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
