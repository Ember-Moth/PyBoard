<div class="row row-cards">
  <div class="col-sm-6 col-lg-3">
    <div class="card">
      <div class="card-body">
        <div class="subheader">订单数</div>
        <div class="h1 mb-0">{{ overview.order_count or 0 }}</div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-lg-3">
    <div class="card">
      <div class="card-body">
        <div class="subheader">已支付订单</div>
        <div class="h1 mb-0">{{ overview.paid_count or 0 }}</div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-lg-3">
    <div class="card">
      <div class="card-body">
        <div class="subheader">成交金额</div>
        <div class="h1 mb-0">{{ overview.paid_total or 0 }}</div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-lg-3">
    <div class="card">
      <div class="card-body">
        <div class="subheader">失败任务</div>
        <div class="h1 mb-0">{{ queue.failed_jobs }}</div>
      </div>
    </div>
  </div>
  <div class="col-12">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">系统状态</h3>
      </div>
      <div class="table-responsive">
        <table class="table table-vcenter card-table">
          <tbody>
            <tr><td>Python</td><td>{{ system.python }}</td></tr>
            <tr><td>平台</td><td>{{ system.platform }}</td></tr>
            <tr><td>磁盘使用</td><td>{{ system.disk.used }} / {{ system.disk.total }}</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
