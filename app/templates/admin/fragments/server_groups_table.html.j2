<div class="card">
  <div class="card-header">
    <div class="card-title">服务器分组</div>
    <div class="ms-auto">
      <button class="btn btn-sm btn-primary" type="button" hx-get="/admin/fragments/servers/groups/form" hx-target="#modal-root" hx-swap="innerHTML">创建</button>
    </div>
  </div>
  <div class="table-responsive">
    <table class="table table-vcenter card-table">
      <thead><tr><th>编号</th><th>分组名称</th><th>关联用户</th><th>关联节点</th><th class="w-1"></th></tr></thead>
      <tbody>
        {% for group in groups %}
        <tr>
          <td>{{ group.id }}</td>
          <td>{{ group.name }}</td>
          <td>{{ group.user_count }}</td>
          <td>{{ group.server_count }}</td>
          <td>
            <div class="btn-list flex-nowrap">
              <button class="btn btn-sm" type="button" hx-get="/admin/fragments/servers/groups/form?group_id={{ group.id }}" hx-target="#modal-root" hx-swap="innerHTML">编辑</button>
              <form hx-post="/admin/actions/servers/groups/{{ group.id }}/delete" hx-target="#server-groups-table" hx-swap="innerHTML" hx-confirm="确认删除该分组？">
                <input type="hidden" name="csrf_token" value="{{ request.cookies.get('admin_csrf') }}">
                <button class="btn btn-sm btn-outline-danger" type="submit">删除</button>
              </form>
            </div>
          </td>
        </tr>
        {% else %}
        <tr><td colspan="5" class="text-center text-secondary py-4">暂无服务器分组</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
