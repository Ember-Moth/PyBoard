<div class="card">
  <div class="card-header">
    <div class="card-title">邮件日志</div>
    <div class="ms-auto text-secondary">从第 {{ offset + 1 }} 条开始，最多显示 {{ limit }} 条</div>
  </div>
  <div class="table-responsive">
    <table class="table table-vcenter card-table table-striped">
      <thead><tr><th>编号</th><th>收件人</th><th>邮件主题</th><th>邮件模板</th><th>投递状态</th><th>创建时间</th><th class="w-1"></th></tr></thead>
      <tbody>
        {% for log in logs %}
        <tr>
          <td>{{ log.id }}</td>
          <td>{{ log.email }}</td>
          <td>{{ log.subject }}</td>
          <td><code>{{ log.template_name }}</code></td>
          <td>{% if log.error %}<span class="badge bg-red-lt">失败</span>{% else %}<span class="badge bg-green-lt">成功</span>{% endif %}</td>
          <td>{{ log.created_at }}</td>
          <td><button class="btn btn-sm" type="button" hx-get="/admin/fragments/mail/log-detail?log_id={{ log.id }}" hx-target="#modal-root" hx-swap="innerHTML">详情</button></td>
        </tr>
        {% else %}
        <tr><td colspan="7" class="text-center text-secondary py-4">暂无邮件日志</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
