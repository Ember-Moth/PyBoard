{% set is_create = knowledge is none %}
<div class="modal modal-blur d-block" tabindex="-1" role="dialog">
  <div class="modal-dialog modal-xl modal-dialog-centered" role="document">
    <div class="modal-content">
      <form hx-post="{% if is_create %}/admin/actions/knowledge{% else %}/admin/actions/knowledge/{{ knowledge.id }}{% endif %}" hx-target="#modal-root" hx-swap="innerHTML">
        <input type="hidden" name="csrf_token" value="{{ request.cookies.get('admin_csrf') }}">
        <div class="modal-header">
          <h5 class="modal-title">{% if is_create %}创建知识{% else %}编辑知识 #{{ knowledge.id }}{% endif %}</h5>
          <button type="button" class="btn-close" onclick="document.getElementById('modal-root').innerHTML=''"></button>
        </div>
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-md-2">
              <label class="form-label">语言</label>
              <input name="language" class="form-control" value="{{ knowledge.language if knowledge else 'zh' }}" required maxlength="5">
            </div>
            <div class="col-md-4">
              <label class="form-label">分类</label>
              <input name="category" class="form-control" value="{{ knowledge.category if knowledge else '' }}" required>
            </div>
            <div class="col-md-4">
              <label class="form-label">标题</label>
              <input name="title" class="form-control" value="{{ knowledge.title if knowledge else '' }}" required>
            </div>
            <div class="col-md-2">
              <label class="form-label">排序</label>
              <input name="sort" type="number" class="form-control" value="{{ knowledge.sort if knowledge and knowledge.sort is not none else '' }}">
            </div>
            <div class="col-12">
              <label class="form-label">正文</label>
              <textarea name="body" class="form-control font-monospace" rows="12" required>{{ knowledge.body if knowledge else '' }}</textarea>
            </div>
            <div class="col-12">
              <label class="form-check">
                <input class="form-check-input" type="checkbox" name="show" value="1" {% if knowledge and knowledge.show %}checked{% endif %}>
                <span class="form-check-label">展示</span>
              </label>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn" onclick="document.getElementById('modal-root').innerHTML=''">取消</button>
          <button type="submit" class="btn btn-primary">{% if is_create %}创建{% else %}保存{% endif %}</button>
        </div>
      </form>
    </div>
  </div>
</div>
<div class="modal-backdrop fade show"></div>
