<div class="card">
  <div class="card-header">
    <ul class="nav nav-tabs card-header-tabs">
      {% for group_key in config.keys() %}
      <li class="nav-item">
        <button class="nav-link {% if group_key == active_group %}active{% endif %}" type="button" hx-get="/admin/fragments/settings/groups?active_group={{ group_key }}" hx-target="#settings-groups" hx-swap="innerHTML">
          {{ labels.get(group_key, group_key) }}
        </button>
      </li>
      {% endfor %}
    </ul>
  </div>
  <form hx-post="/admin/actions/settings/groups/{{ active_group }}" hx-target="#settings-groups" hx-swap="innerHTML">
    <input type="hidden" name="csrf_token" value="{{ request.cookies.get('admin_csrf') }}">
    <div class="card-body">
      <div class="row g-3">
        {% for key, value in config[active_group].items() %}
        {% set is_json = value is mapping or (value is sequence and value is not string) %}
        {% set type_hint = "json" if is_json else ("int" if value is number else "str") %}
        <div class="col-md-6">
          <label class="form-label">{{ field_labels.get(key, "配置项") }}</label>
          <input type="hidden" name="_type_{{ key }}" value="{{ type_hint }}">
          {% if is_json %}
          <textarea class="form-control" rows="3" name="{{ key }}">{{ value | tojson }}</textarea>
          {% else %}
          <input class="form-control" name="{{ key }}" value="{{ '' if value is none else value }}">
          {% endif %}
        </div>
        {% endfor %}
      </div>
    </div>
    <div class="card-footer d-flex">
      <button class="btn btn-primary" type="submit">保存 {{ labels.get(active_group, active_group) }}</button>
      <div class="ms-auto btn-list">
        {% if active_group == "email" %}
        <button class="btn btn-outline-secondary" type="button" hx-post="/admin/actions/settings/mail/test" hx-include="closest form" hx-target="#modal-root" hx-swap="innerHTML">发送测试邮件</button>
        {% endif %}
        {% if active_group == "telegram" %}
        <button class="btn btn-outline-secondary" type="button" hx-post="/admin/actions/settings/telegram/webhook" hx-include="closest form" hx-target="#modal-root" hx-swap="innerHTML">设置 Webhook</button>
        {% endif %}
      </div>
    </div>
  </form>
</div>
