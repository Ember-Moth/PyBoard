<div class="card">
  <div class="card-header">
    <form class="row g-2 align-items-center w-100" hx-get="{{ fragment_path or '/admin/fragments/dashboard/user-traffic' }}" hx-target="{{ fragment_target or '#dashboard-user-traffic' }}" hx-swap="innerHTML">
      <div class="col-12 col-lg">
        <h3 class="card-title mb-0">用户流量查询</h3>
        <div class="text-secondary small">输入用户编号查看最近流量记录。</div>
      </div>
      <div class="col-12 col-md-4 col-lg-3">
        <input name="user_id" type="number" class="form-control" placeholder="用户编号" value="{{ user_id }}">
      </div>
      <div class="col-12 col-md-auto">
        <button class="btn btn-primary w-100" type="submit">查询</button>
      </div>
    </form>
  </div>
  {% if user_id %}
  <div class="table-responsive">
    <table class="table card-table table-vcenter">
      <thead><tr><th>记录时间</th><th>节点</th><th>上行</th><th>下行</th><th>倍率</th></tr></thead>
      <tbody>
        {% for item in traffic %}
        <tr><td>{{ item.record_at | datetime }}</td><td>{{ item.server_id }}</td><td>{{ item.u }}</td><td>{{ item.d }}</td><td>{{ item.server_rate }}</td></tr>
        {% else %}
        <tr><td colspan="5" class="text-center text-secondary py-4">暂无用户流量记录</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% endif %}
</div>
