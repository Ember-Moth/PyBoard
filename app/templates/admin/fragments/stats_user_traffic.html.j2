<div class="card">
  <div class="card-header">
    <form class="row g-2 w-100" hx-get="/admin/fragments/stats/user-traffic" hx-target="#stats-user-traffic" hx-swap="innerHTML">
      <div class="col-md-3">
        <input name="user_id" type="number" class="form-control" placeholder="用户编号" value="{{ user_id }}">
      </div>
      <div class="col-md-2">
        <button class="btn btn-primary" type="submit">查询用户流量</button>
      </div>
    </form>
  </div>
  {% if user_id %}
  <div class="table-responsive">
    <table class="table card-table table-vcenter">
      <thead><tr><th>记录时间</th><th>节点</th><th>上行</th><th>下行</th><th>倍率</th></tr></thead>
      <tbody>
        {% for item in traffic %}
        <tr><td>{{ item.record_at }}</td><td>{{ item.server_id }}</td><td>{{ item.u }}</td><td>{{ item.d }}</td><td>{{ item.server_rate }}</td></tr>
        {% else %}
        <tr><td colspan="5" class="text-center text-secondary py-4">暂无用户流量记录</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% endif %}
</div>
