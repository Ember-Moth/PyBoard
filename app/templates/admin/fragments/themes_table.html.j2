<div class="card">
  <div class="card-header">
    <div class="card-title">主题列表</div>
    <div class="ms-auto text-secondary">当前：{{ themes.active }}</div>
  </div>
  <div class="table-responsive">
    <table class="table table-vcenter card-table">
      <thead><tr><th>名称</th><th>说明</th><th>配置项</th><th class="w-1"></th></tr></thead>
      <tbody>
        {% for name, theme in themes.themes.items() %}
        <tr>
          <td><code>{{ name }}</code></td>
          <td>{{ theme.name if theme.name is defined else "-" }}</td>
          <td>{{ theme.configs | length }}</td>
          <td><button class="btn btn-sm" type="button" hx-get="/admin/fragments/themes/config-form?name={{ name }}" hx-target="#modal-root" hx-swap="innerHTML">配置</button></td>
        </tr>
        {% else %}
        <tr><td colspan="4" class="text-center text-secondary py-4">暂无本地主题</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
