{% set ticket = detail.ticket %}
<div class="modal modal-blur d-block" tabindex="-1" role="dialog">
  <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">工单 #{{ ticket.id }} {{ ticket.subject }}</h5>
        <button type="button" class="btn-close" onclick="document.getElementById('modal-root').innerHTML=''"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          {% if ticket.status == 0 %}<span class="badge bg-blue-lt">处理中</span>{% else %}<span class="badge bg-secondary-lt">已关闭</span>{% endif %}
          <span class="text-secondary ms-2">用户 {{ ticket.user_id }}</span>
        </div>
        <div class="list-group mb-3">
          {% for message in detail.messages %}
          <div class="list-group-item">
            <div class="d-flex">
              <strong>{% if message.is_me %}客服{% else %}用户 {{ message.user_id }}{% endif %}</strong>
              <span class="text-secondary ms-auto">{{ message.created_at | datetime }}</span>
            </div>
            <div class="mt-2" style="white-space: pre-wrap;">{{ message.message }}</div>
          </div>
          {% else %}
          <div class="list-group-item text-secondary">暂无消息</div>
          {% endfor %}
        </div>
        {% if ticket.status == 0 %}
        <form hx-post="/admin/actions/tickets/{{ ticket.id }}/reply" hx-target="#modal-root" hx-swap="innerHTML">
          <input type="hidden" name="csrf_token" value="{{ request.cookies.get('admin_csrf') }}">
          <label class="form-label">回复</label>
          <textarea name="message" class="form-control" rows="4" required></textarea>
          <div class="mt-3 btn-list">
            <button class="btn btn-primary" type="submit">发送回复</button>
            <button class="btn btn-outline-secondary" type="button" hx-post="/admin/actions/tickets/{{ ticket.id }}/close" hx-include="closest form" hx-vals='{"target":"detail"}' hx-target="#modal-root" hx-swap="innerHTML">关闭工单</button>
          </div>
        </form>
        {% endif %}
      </div>
    </div>
  </div>
</div>
<div class="modal-backdrop fade show"></div>
