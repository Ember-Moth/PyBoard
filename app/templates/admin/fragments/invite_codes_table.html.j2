<div class="card">
  <div class="card-header">
    <div class="card-title">邀请码</div>
    <div class="ms-auto text-secondary">从第 {{ offset + 1 }} 条开始，最多显示 {{ limit }} 条</div>
  </div>
  <div class="table-responsive">
    <table class="table table-vcenter card-table table-striped">
      <thead>
        <tr>
          <th>编号</th>
          <th>归属用户</th>
          <th>邀请码</th>
          <th>访问次数</th>
          <th>状态</th>
          <th>创建时间</th>
          <th class="w-1"></th>
        </tr>
      </thead>
      <tbody>
        {% for code in codes %}
        <tr>
          <td>{{ code.id }}</td>
          <td>{{ code.user_id }}</td>
          <td><code>{{ code.code }}</code></td>
          <td>{{ code.pv }}</td>
          <td>{% if code.status == 0 %}<span class="badge bg-green-lt">可用</span>{% else %}<span class="badge bg-secondary-lt">停用</span>{% endif %}</td>
          <td>{{ code.created_at }}</td>
          <td>
            <div class="btn-list flex-nowrap">
              <button class="btn btn-sm" type="button" hx-get="/admin/fragments/invite/code-form?invite_id={{ code.id }}" hx-target="#modal-root" hx-swap="innerHTML">编辑</button>
              <form hx-post="/admin/actions/invite/codes/{{ code.id }}/delete" hx-target="#invite-codes-table" hx-swap="innerHTML" hx-confirm="确认删除该邀请码？">
                <input type="hidden" name="csrf_token" value="{{ request.cookies.get('admin_csrf') }}">
                <input type="hidden" name="offset" value="{{ offset }}">
                <input type="hidden" name="limit" value="{{ limit }}">
                <button class="btn btn-sm btn-outline-danger" type="submit">删除</button>
              </form>
            </div>
          </td>
        </tr>
        {% else %}
        <tr><td colspan="7" class="text-center text-secondary py-4">暂无邀请码</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
