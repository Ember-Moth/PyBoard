{% extends "admin/layouts/base.html.j2" %}
{% block body %}
<div class="page">
  <header class="navbar navbar-expand-md d-print-none" data-bs-theme="dark">
    <div class="container-xl">
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbar-menu" aria-controls="navbar-menu" aria-expanded="false" aria-label="打开导航">
        <span class="navbar-toggler-icon"></span>
      </button>
      <h1 class="navbar-brand navbar-brand-autodark pe-0 pe-md-3">
        <a href="/admin/dashboard">Admin</a>
      </h1>
      <div class="navbar-nav flex-row order-md-last">
        <div class="nav-item d-none d-md-flex align-items-center me-3 text-white-50">
          {{ title }}
        </div>
        <div class="nav-item">
          <a href="/admin/logout" class="btn btn-outline-light">退出</a>
        </div>
      </div>
    </div>
  </header>
  {% include "admin/partials/sidebar.html.j2" %}
  <div class="page-wrapper">
    <div class="page-body">
      <div class="container-xl">
        {% block content %}{% endblock %}
      </div>
    </div>
  </div>
</div>
<div id="modal-root"></div>
{% endblock %}
